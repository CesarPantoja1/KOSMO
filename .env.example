# KOSMO local Docker environment example.
#
# Copy to `.env` only if you want to override the docker-compose.yml defaults.
# The values below are for local development, not production.

ENV=development
LOG_LEVEL=DEBUG
FRONTEND_PORT=3000
BACKEND_PORT=8000

# Postgres (pgvector)
POSTGRES_USER=kosmo
POSTGRES_PASSWORD=kosmo
POSTGRES_DB=kosmo_dev
POSTGRES_PORT=5432

# MongoDB
MONGO_USER=kosmo
MONGO_PASSWORD=kosmo
MONGO_DB=kosmo_agent_memory
MONGO_PORT=27017

# Redis
REDIS_PORT=6379

# Backend app
RUN_MIGRATIONS=1
DEV_GENERATE_SECRETS=1
FERNET_MASTER_KEY=qn9GZmTM--RH5MVh3kLmyS-oeHYCmnYCVPW9BRFLuik=
JWT_ISSUER=kosmo
JWT_AUDIENCE=kosmo-api
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_SECONDS=604800

LLM_PROVIDER=noop
LLM_MODEL=noop
LLM_API_KEY=

API_VERSION=v1
CORS_ALLOWED_ORIGINS=http://localhost:3000
LOGFIRE_TOKEN=
OTEL_SERVICE_NAME=kosmo-backend
OTEL_ENVIRONMENT=development

# Frontend app
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=KOSMO
NEXT_PUBLIC_APP_ENV=development
