# =============================================================================
# KOSMO — .env.example
# -----------------------------------------------------------------------------
# Plantilla SEGURA. Copiar a `.env` y rellenar localmente.
# NUNCA commitear el `.env` real ni claves PEM.
# Las variables aquí son consumidas por docker-compose (interpolación).
# =============================================================================

# -----------------------------------------------------------------------------
# Postgres (pgvector)
# -----------------------------------------------------------------------------
POSTGRES_USER=kosmo
POSTGRES_PASSWORD=changeme
POSTGRES_DB=kosmo_dev
POSTGRES_PORT=5432

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
MONGO_USER=kosmo
MONGO_PASSWORD=changeme
MONGO_DB=kosmo_agent_memory
MONGO_PORT=27017

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PORT=6379