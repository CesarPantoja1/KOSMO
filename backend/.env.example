# Runtime
ENV=development
LOG_LEVEL=DEBUG

# Observability
LOGFIRE_TOKEN=               # Dejar vacío para local dev (todo se ve en consola)
OTEL_SERVICE_NAME=kosmo-backend
OTEL_ENVIRONMENT=development  # or production

# Seguridad
# JWT_PRIVATE_KEY_PEM=           # Contenido completo del PEM privado
# JWT_PUBLIC_KEY_PEM=            # Contenido completo del PEM público
# Rutas a archivos PEM (fallback para desarrollo local)
JWT_PRIVATE_KEY_PATH=./.secrets/jwt_private.pem
JWT_PUBLIC_KEY_PATH=./.secrets/jwt_public.pem
FERNET_MASTER_KEY=
ARGON2_MEMORY_KIB=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# LLM (BYOK)
# Opciones: noop (mock para desarrollo), deepseek, anthropic, openai, gemini
LLM_PROVIDER=noop
LLM_MODEL=deepseek-chat
# Para usar DeepSeek, cambiar LLM_PROVIDER=deepseek y poner tu API key:
# LLM_PROVIDER=deepseek
# LLM_API_KEY=sk-tu-api-key-aqui
LLM_API_KEY=

# Persistencia
DATABASE_URL=postgresql+asyncpg://kosmo:kosmo@localhost:5432/kosmo_dev
MONGO_URL=mongodb://localhost:27017/kosmo_agent_memory
REDIS_URL=redis://localhost:6379/0

# LangSmith tracing (trazas de langgraph + langchain)
# Activar con LANGCHAIN_TRACING_V2=true y poner tu API key
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=kosmo-backend
# LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# API
API_VERSION=v1
CORS_ALLOWED_ORIGINS=http://localhost:3000
