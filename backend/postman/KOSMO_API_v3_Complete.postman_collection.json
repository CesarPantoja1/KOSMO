    {
      "name": "3. Discovery (Fase 1)",
      "description": "Documento de descubrimiento generado por IA (orquestación multiagente con LangGraph). El documento es un árbol JSON enriquecido compatible con editores WYSIWYG (ProseMirror/TipTap). Incluye índice de navegación extraído de headings.\n\nFlujo: Generate → Get → (editar) Save → Regenerate.",
      "item": [
        {
          "name": "3.1 Generar Discovery (IA)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  console.log('Discovery generado | Secciones:', body.sections.length);",
                  "  body.sections.forEach(function(s) { console.log('  [' + s.level + ']', s.title, '-> #' + s.anchor); });",
                  "  console.log('updated_at:', body.updated_at);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/projects/{{project_id}}/discovery/generate", "host": ["{{base_url}}"], "path": ["api", "v1", "projects", "{{project_id}}", "discovery", "generate"] }
          }
        },
        {
          "name": "3.2 Obtener Discovery",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  console.log('Documento:', body.document.type, '| Nodos:', body.document.content.length);",
                  "  console.log('Secciones (índice):', body.sections.length);",
                  "  body.sections.forEach(function(s) { console.log('  [' + s.level + ']', s.title); });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/projects/{{project_id}}/discovery", "host": ["{{base_url}}"], "path": ["api", "v1", "projects", "{{project_id}}", "discovery"] }
          }
        },
        {
          "name": "3.3 Guardar Discovery (edición manual + aprendizaje)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  console.log('Guardado. Secciones:', body.sections.length);",
                  "  console.log('updated_at:', body.updated_at);",
                  "} else if (pm.response.code === 422) {",
                  "  console.log('[422] Documento inválido:', pm.response.json().detail);",
                  "} else {",
                  "  console.log('[ERROR]', pm.response.text());",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"document\": {\n    \"type\": \"doc\",\n    \"content\": [\n      {\n        \"type\": \"heading\",\n        \"attrs\": { \"level\": 2, \"id\": \"vision-del-producto\" },\n        \"content\": [{ \"type\": \"text\", \"text\": \"Visión del producto\" }]\n      },\n      {\n        \"type\": \"paragraph\",\n        \"content\": [\n          { \"type\": \"text\", \"text\": \"Plataforma \" },\n          { \"type\": \"text\", \"text\": \"web\", \"marks\": [{ \"type\": \"bold\" }] },\n          { \"type\": \"text\", \"text\": \" de gestión de inventario en tiempo real para \" },\n          { \"type\": \"text\", \"text\": \"pequeñas y medianas\", \"marks\": [{ \"type\": \"italic\" }] },\n          { \"type\": \"text\", \"text\": \" empresas con trazabilidad completa.\" }\n        ]\n      },\n      {\n        \"type\": \"bulletList\",\n        \"content\": [\n          {\n            \"type\": \"listItem\",\n            \"content\": [{ \"type\": \"paragraph\", \"content\": [{ \"type\": \"text\", \"text\": \"Control de stock en tiempo real\" }] }]\n          },\n          {\n            \"type\": \"listItem\",\n            \"content\": [{ \"type\": \"paragraph\", \"content\": [{ \"type\": \"text\", \"text\": \"Alertas de inventario bajo con notificaciones\" }] }]\n          },\n          {\n            \"type\": \"listItem\",\n            \"content\": [{ \"type\": \"paragraph\", \"content\": [{ \"type\": \"text\", \"text\": \"Reportes de movimientos\" }] }]\n          }\n        ]\n      }\n    ]\n  }\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/projects/{{project_id}}/discovery", "host": ["{{base_url}}"], "path": ["api", "v1", "projects", "{{project_id}}", "discovery"] }
          }
        },
        {
          "name": "3.4 Regenerar Discovery (IA)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  var body = pm.response.json();",
                  "  console.log('Regenerado. Secciones:', body.sections.length);",
                  "  body.sections.forEach(function(s) { console.log('  [' + s.level + ']', s.title); });",
                  "} else if (pm.response.code === 404) {",
                  "  console.log('[404] No hay documento previo. Ejecuta 3.1 primero.');",
                  "} else {",
                  "  console.log('[ERROR]', pm.response.text());",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/projects/{{project_id}}/discovery/regenerate", "host": ["{{base_url}}"], "path": ["api", "v1", "projects", "{{project_id}}", "discovery", "regenerate"] }
          }
        }
      ]
    },
    {
      "name": "4. Features (Fase 2)",
      "description": "Gestión de características. La IA genera y persiste 5 features iniciales. Se pueden crear manualmente, sugerir alternativas (3, no persiste), mejorar con IA y cambiar estado (Borrador ↔ Aprobada). Solo features en Borrador se pueden editar/mejorar.",
      "item": [
        {
          "name": "4.1 Generar Features (IA, persiste 5)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
                  "var body = pm.response.json();",
                  "pm.test('Generó features', function () { pm.expect(body.features).to.be.an('array'); });",
                  "if (body.features && body.features.length > 0) {",
                  "  pm.collectionVariables.set('feature_id', body.features[0].id);",
                  "}",
                  "console.log('Features generadas:', body.features.length);",
                  "body.features.forEach(function(f, i) { console.log('  ' + (i+1) + '.', f.title, '(' + f.status + ')'); });"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/projects/{{project_id}}/features/generate", "host": ["{{base_url}}"], "path": ["api", "v1", "projects", "{{project_id}}", "features", "generate"] }
          }
        },
        {
          "name": "4.2 Listar Features",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
