            "register"
          ]
        },
        "description": "Registra `lockout@kosmo.dev`, el usuario que se usará para acumular intentos fallidos en los pasos 11 y 12. Acepta **201** (creado) o **409** (ya existe)."
      },
      "response": []
    },
    {
      "name": "11. Lockout — Acumular 10 fallos (paso 1/2)",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "var url = pm.variables.get('base_url') + '/api/v1/auth/authorize';",
              "var body = JSON.stringify({ email: 'lockout@kosmo.dev', password: 'wrong-lockout-pwd', code_challenge: 'E9Melhoa2OwvFrEMTJguCHaoeK1t8URWbuGJSstw-cM', code_challenge_method: 'S256', scopes: [] });",
              "var req = { url: url, method: 'POST', header: [{ key: 'Content-Type', value: 'application/json' }], body: { mode: 'raw', raw: body } };",
              "function fill(n, done) {",
              "    if (n === 0) { done(); return; }",
              "    pm.sendRequest(req, function(err, res) { fill(n - 1, done); });",
              "}",
              "fill(9, function() {});"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('401 — décimo fallo registrado, cuenta aún no bloqueada', function() {",
              "    pm.response.to.have.status(401);",
              "});",
              "pm.test('error = invalid_grant (no account_locked todavía)', function() {",
              "    pm.expect(pm.response.json().error).to.eql('invalid_grant');",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"lockout@kosmo.dev\",\n  \"password\": \"wrong-lockout-pwd\",\n  \"code_challenge\": \"E9Melhoa2OwvFrEMTJguCHaoeK1t8URWbuGJSstw-cM\",\n  \"code_challenge_method\": \"S256\",\n  \"scopes\": []\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/auth/authorize",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "auth",
            "authorize"
