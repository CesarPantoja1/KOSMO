            "body": { "mode": "raw", "raw": "{\n  \"change_type\": \"add_class\",\n  \"class_id\": null,\n  \"requirement_id\": null,\n  \"new_value\": {\"class_name\": \"NotificationService\"},\n  \"instruction\": \"Agregar un servicio de notificaciones al modelo\"\n}" },
            "url": { "raw": "{{base_url}}/api/v1/specs/{{spec_id}}/canvas", "host": ["{{base_url}}"], "path": ["api", "v1", "specs", "{{spec_id}}", "canvas"] }
          }
        }
      ]
    }
  ]
}
