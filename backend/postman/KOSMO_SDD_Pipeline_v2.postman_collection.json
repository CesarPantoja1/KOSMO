          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Gestion avanzada de inventario con alertas inteligentes\",\n  \"description\": \"Sistema de gestion de inventario con alertas predictivas basadas en patrones historicos de consumo.\"\n}" },
            "url": { "raw": "{{base_url}}/api/v1/features/{{feature_id}}/apply-improvement", "host": ["{{base_url}}"], "path": ["api", "v1", "features", "{{feature_id}}", "apply-improvement"] }
          }
        }
      ]
    },
    {
      "name": "5. Requisitos (Fase 3) - Documento Enriquecido",
      "description": "Requisitos EARS por feature en formato de documento enriquecido.\n\nFormato: un unico documento con secciones por taxonomia EARS:\n- Requisitos Ubicuos (Ubiquitous)\n- Requisitos Basados en Eventos (Event-driven)\n- Requisitos Determinados por el Estado (State-driven)\n- Requisitos Opcionales (Optional)\n- Respuestas ante Fallos (Unwanted)\n- Requisitos Complejos (Complex)\n\nLa feature DEBE estar Aprobada (409 si Borrador).\nEl endpoint /regenerate permite a la IA reescribir todos los requisitos.",
      "item": [
        {
          "name": "5.1 Obtener Requisitos (documento + indice + header feature)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('200 OK', function () { pm.response.to.have.status(200); });",
                  "if (pm.response.code === 200) {",
                  "    var body = pm.response.json();",
                  "    console.log('[OK] Feature:', body.feature_title);",
                  "    console.log('[OK] Secciones:', body.sections.length);",
                  "    body.sections.forEach(function(s) {",
                  "        console.log('  [' + s.level + ']', s.title);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/features/{{feature_id}}/requirements", "host": ["{{base_url}}"], "path": ["api", "v1", "features", "{{feature_id}}", "requirements"] }
          }
        },
        {
          "name": "5.2 Generar Requisitos con IA (feature Aprobada requerida)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var body = pm.response.json();",
                  "    console.log('[OK] Requisitos generados para:', body.feature_title);",
                  "    console.log('[OK] Secciones:', body.sections.length);",
                  "    body.sections.forEach(function(s) {",
                  "        console.log('  [' + s.level + ']', s.title);",
                  "    });",
                  "} else if (pm.response.code === 409) {",
                  "    console.log('[409] La feature debe estar Aprobada (usa 4.5 Toggle)');",
                  "} else if (pm.response.code === 404) {",
                  "    console.log('[404] Feature o requisitos no encontrados');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/features/{{feature_id}}/requirements/generate", "host": ["{{base_url}}"], "path": ["api", "v1", "features", "{{feature_id}}", "requirements", "generate"] }
          }
        },
        {
          "name": "5.3 Guardar Requisitos (editor envia arbol JSON)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var body = pm.response.json();",
                  "    console.log('[OK] Requisitos guardados');",
                  "    console.log('  Secciones:', body.sections.length);",
                  "    console.log('  updated_at:', body.updated_at);",
                  "} else if (pm.response.code === 422) {",
                  "    console.log('[422] Documento invalido');",
                  "} else {",
                  "    console.log('[ERROR]', pm.response.text());",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"document\": {\n    \"type\": \"doc\",\n    \"content\": [\n      {\n        \"type\": \"heading\",\n        \"attrs\": { \"level\": 2, \"id\": \"requisitos-ubicuos\" },\n        \"content\": [\n          { \"type\": \"text\", \"text\": \"Requisitos Ubicuos\" }\n        ]\n      },\n      {\n        \"type\": \"heading\",\n        \"attrs\": { \"level\": 3, \"id\": \"r-1\" },\n        \"content\": [\n          { \"type\": \"text\", \"text\": \"R-1\" }\n        ]\n      },\n      {\n        \"type\": \"paragraph\",\n        \"content\": [\n          { \"type\": \"text\", \"marks\": [{ \"type\": \"bold\" }], \"text\": \"Sistema:\" },\n          { \"type\": \"text\", \"text\": \" El sistema shall permitir gestion completa de inventario con trazabilidad de cambios.\" }\n        ]\n      }\n    ]\n  }\n}"
            },
            "url": { "raw": "{{base_url}}/api/v1/features/{{feature_id}}/requirements", "host": ["{{base_url}}"], "path": ["api", "v1", "features", "{{feature_id}}", "requirements"] }
          }
        },
        {
          "name": "5.4 Regenerar Requisitos con IA",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var body = pm.response.json();",
                  "    console.log('[OK] Requisitos regenerados por IA');",
                  "    console.log('  Feature:', body.feature_title);",
                  "    console.log('  Secciones:', body.sections.length);",
                  "} else if (pm.response.code === 409) {",
                  "    console.log('[409] La feature debe estar Aprobada');",
                  "} else if (pm.response.code === 404) {",
                  "    console.log('[404] No hay requisitos previos. Ejecuta 5.2 primero.');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/features/{{feature_id}}/requirements/regenerate", "host": ["{{base_url}}"], "path": ["api", "v1", "features", "{{feature_id}}", "requirements", "regenerate"] }
          }
        }
      ]
    },
    {
      "name": "6. SDD Pipeline (Clasico)",
      "description": "Pipeline Spec-Driven Development clasico sobre SpecDocument (estructurado, no documento enriquecido).",
      "item": [
        {
          "name": "6.1 Discovery - Crear Spec",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var data = pm.response.json();",
                  "    pm.collectionVariables.set('spec_id', data.id);",
                  "    console.log('[OK] Spec:', data.id, '| Fase:', data.phase);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"text\": \"Una API REST para gestion de tareas con autenticacion JWT y arquitectura hexagonal.\",\n  \"assumptions\": [\"Usuarios existen en el sistema\"],\n  \"constraints\": [\"PostgreSQL\", \"Arquitectura hexagonal\"]\n}" },
            "url": { "raw": "{{base_url}}/api/v1/projects/{{project_id}}/specs", "host": ["{{base_url}}"], "path": ["api", "v1", "projects", "{{project_id}}", "specs"] }
          }
        },
        {
          "name": "6.2 Avanzar a Requirements (EARS)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/specs/{{spec_id}}/advance/requirements", "host": ["{{base_url}}"], "path": ["api", "v1", "specs", "{{spec_id}}", "advance", "requirements"] }
          }
        },
        {
          "name": "6.3 Avanzar a Design (UML)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/specs/{{spec_id}}/advance/design", "host": ["{{base_url}}"], "path": ["api", "v1", "specs", "{{spec_id}}", "advance", "design"] }
          }
        },
        {
          "name": "6.4 Avanzar a Tasks",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/specs/{{spec_id}}/advance/tasks", "host": ["{{base_url}}"], "path": ["api", "v1", "specs", "{{spec_id}}", "advance", "tasks"] }
          }
        },
        {
          "name": "6.5 Obtener Spec (estado completo)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{access_token}}" }],
            "url": { "raw": "{{base_url}}/api/v1/specs/{{spec_id}}", "host": ["{{base_url}}"], "path": ["api", "v1", "specs", "{{spec_id}}"] }
          }
        }
      ]
    },
    {
      "name": "7. Health + Schemas + Canvas",
      "item": [
        {
          "name": "7.1 Health check",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/health", "host": ["{{base_url}}"], "path": ["health"] }
          }
        },
        {
          "name": "7.2 Listar esquemas JSON Schema",
          "request": {
            "method": "GET",
            "url": { "raw": "{{base_url}}/api/v1/schemas", "host": ["{{base_url}}"], "path": ["api", "v1", "schemas"] }
          }
        },
        {
          "name": "7.3 Canvas Sync (editar diseno)",
          "request": {
