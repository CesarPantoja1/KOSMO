                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{access_token}}" }
            ],
            "url": { "raw": "{{base_url}}/api/v1/features/{{feature_id}}/improve", "host": ["{{base_url}}"], "path": ["api", "v1", "features", "{{feature_id}}", "improve"] }
